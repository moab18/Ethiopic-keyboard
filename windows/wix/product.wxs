<!--
  Ethiopic TSF IME — WiX MSI Installer
  =====================================
  Build:   windows\build-msi.bat
  Output:  build-win\EthiopicKeyboard-0.1.0-x64.msi

  Requires WiX Toolset v4+ (https://wixtoolset.org/)
    dotnet tool install -g wix
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

    <!--
      UpgradeCode: stable GUID across versions.
      Change this ONLY when breaking upgrade compatibility.
    -->
    <?define UpgradeCode="9F3B7C2A-8D4E-4F1A-B5C6-2E7A9D3F4B1C"?>
    <?define ProductName="Ethiopic Keyboard"?>
    <?define Manufacturer="Moab"?>
    <?define Version="0.1.0"?>

    <Package Name="$(var.ProductName)"
             Manufacturer="$(var.Manufacturer)"
             Version="$(var.Version)"
             UpgradeCode="$(var.UpgradeCode)"
             Language="1033"
             InstallerVersion="500"
             Compressed="yes"
             Scope="perMachine">

    <!--
      Allow major upgrades: uninstall old version before installing new.
    -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of $(var.ProductName) is already installed."
                   AllowSameVersionUpgrades="yes" />


    <MediaTemplate EmbedCab="yes" />

    <!--
      ── UI ────────────────────────────────────────────────────────
      WixUI_InstallDir gives: welcome, directory chooser, progress, finish.
      The install directory is bound to INSTALLFOLDER below.
      To add a license page, set WixUILicenseRtf to an .rtf file and use
      WixUI_Minimal or WixUI_FeatureTree instead.
    -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="windows\wix\license.rtf" />

    <!--
      ── Install directory ─────────────────────────────────────────
    -->
    <StandardDirectory Id="ProgramFiles64Folder">
        <Directory Id="ManufacturerFolder" Name="$(var.Manufacturer)">
            <Directory Id="INSTALLFOLDER" Name="$(var.ProductName)">

                <!-- Main DLL -->
                <Component Id="C_EthiopicTsfDll"
                           Guid="A1B2C3D4-E5F6-4789-ABCD-EF0123456789"
                           DiskId="1">
                    <File Id="F_EthiopicTsfDll"
                          Name="ethiopic-tsf.dll"
                          Source="build-win\Release\ethiopic-tsf.dll"
                          KeyPath="yes"
                          Checksum="yes" />
                </Component>

                <!-- Data directory -->
                <Directory Id="DataDir" Name="data">
                    <Directory Id="AmharicDir" Name="amharic">

                        <Component Id="C_AmSeraJson"
                                   Guid="B2C3D4E5-F6A7-4890-BCDE-F12345678901"
                                   DiskId="1">
                            <File Id="F_AmSeraJson"
                                  Name="am-sera.json"
                                  Source="data\amharic\am-sera.json"
                                  KeyPath="yes" />
                        </Component>

                        <Component Id="C_WordlistJson"
                                   Guid="C3D4E5F6-A7B8-4901-CDEF-012345678902"
                                   DiskId="1">
                            <File Id="F_WordlistJson"
                                  Name="wordlist.json"
                                  Source="data\amharic\wordlist.json"
                                  KeyPath="yes" />
                        </Component>

                        <Component Id="C_BigramsJson"
                                   Guid="D4E5F6A7-B8C9-4012-DEFA-123456789003"
                                   DiskId="1">
                            <File Id="F_BigramsJson"
                                  Name="bigrams.json"
                                  Source="data\amharic\bigrams.json"
                                  KeyPath="yes" />
                        </Component>

                        <Component Id="C_NamesJson"
                                   Guid="E5F6A7B8-C9D0-4123-EFAB-234567890014"
                                   DiskId="1">
                            <File Id="F_NamesJson"
                                  Name="names.json"
                                  Source="data\amharic\names.json"
                                  KeyPath="yes" />
                        </Component>

                    </Directory>
                </Directory>

            </Directory>
        </Directory>
    </StandardDirectory>

    <!--
      ── Feature tree ──────────────────────────────────────────────
    -->
    <Feature Id="F_EthiopicIME"
             Title="$(var.ProductName)"
             Description="Ethiopic SERA transliteration input method for Windows"
             Level="1"
             Display="expand"
             ConfigurableDirectory="INSTALLFOLDER"
             AllowAdvertise="no">
        <ComponentRef Id="C_EthiopicTsfDll" />
        <ComponentRef Id="C_AmSeraJson" />
        <ComponentRef Id="C_WordlistJson" />
        <ComponentRef Id="C_BigramsJson" />
        <ComponentRef Id="C_NamesJson" />
    </Feature>


    <!--
      ── COM / TSF registration ────────────────────────────────────
      regsvr32.exe /s calls DllRegisterServer which handles:
        - COM class registration (HKCR\CLSID\...)
        - TSF profile registration (ITfInputProcessorProfileMgr)
        - TSF category registration (ITfCategoryMgr)
      Deferred + Impersonate="no" = runs elevated (SYSTEM), required
      for writing to HKCR and calling TSF COM activation.
    -->
    <CustomAction Id="RegisterDll"
                  Directory="INSTALLFOLDER"
                  ExeCommand='"[SystemFolder]regsvr32.exe" /s "[INSTALLFOLDER]ethiopic-tsf.dll"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="UnregisterDll"
                  Directory="INSTALLFOLDER"
                  ExeCommand='"[SystemFolder]regsvr32.exe" /u /s "[INSTALLFOLDER]ethiopic-tsf.dll"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <InstallExecuteSequence>
        <Custom Action="RegisterDll" After="InstallFiles" Condition="NOT Installed" />
        <Custom Action="UnregisterDll" After="InstallInitialize" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    </Package>

</Wix>
